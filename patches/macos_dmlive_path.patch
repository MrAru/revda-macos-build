+fn get_dmlive_bin() -> String {
+    if cfg!(target_os = "macos") {
+        if let Ok(exe) = std::env::current_exe() {
+            if let Some(dir) = exe.parent() {
+                let dmlive = dir.join("dmlive");
+                if dmlive.exists() {
+                    return dmlive.to_string_lossy().to_string();
+                }
+            }
+        }
+    }
+    "dmlive".to_string()
+}
